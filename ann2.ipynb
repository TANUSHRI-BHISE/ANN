   ],
   "source": [
    "# Generate ANDNOT function using McCulloch-Pitts neural net by a python program\n",
    "w1=1\n",
    "w2=-1\n",
    "theta=1\n",
    "inputs=[(0,0),(0,1),(1,0),(1,1)]\n",
    "print(\"X1  X2   | OUTPUT\")\n",
    "for x1,x2 in inputs:\n",
    "    yin=x1*w1+x2*w2\n",
    "    if yin>= theta:\n",
    "        y=1\n",
    "    else:\n",
    "        y=0\n",
    "    print(x1,\"  \",x2,\"  |\",y)"
   ]
  },
